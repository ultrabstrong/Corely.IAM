@page "/accounts/{Id:guid}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inherits EntityDetailPageBase
@inject IRetrievalService RetrievalService
@inject IModificationService ModificationService
@inject IRegistrationService RegistrationService
@inject IDeregistrationService DeregistrationService
@inject IAccountDisplayState AccountDisplayState
@inject IJSRuntime JSRuntime

<PageTitle>@_accountName - Corely IAM</PageTitle>

<div class="management-header">
    <h1><i class="bi bi-building me-2"></i>@_accountName <span class="resource-label">Account</span></h1>
    <a href="@AppRoutes.Dashboard" class="btn btn-outline-secondary btn-sm">Back to Dashboard</a>
</div>

<Alert Message="@_message" Type="@_messageType" OnDismissed="() => _message = null" />

@if (_loading && _accountName == null)
{
    <LoadingSpinner />
}
else
{
    <div class="detail-section">

        <div class="section-divider mb-4">
            <div class="section-divider-label">
                Details
                @if (!_isEditing)
                {
                    <div class="d-flex gap-2">
                        <PermissionView Action="AuthAction.Update" Resource="@PermissionConstants.ACCOUNT_RESOURCE_TYPE" ResourceIds="new[] { Id }">
                            <button class="btn btn-outline-primary btn-sm" @onclick="StartEdit">Edit</button>
                        </PermissionView>
                        <PermissionView Action="AuthAction.Delete" Resource="@PermissionConstants.ACCOUNT_RESOURCE_TYPE" ResourceIds="new[] { Id }">
                            <button class="btn btn-outline-danger btn-sm" @onclick="ConfirmDelete" disabled="@_loading">Delete</button>
                        </PermissionView>
                    </div>
                }
            </div>
            @if (_isEditing)
            {
                <div class="props-grid mb-3">
                    <span class="prop-label">Account Name</span>
                    <div class="prop-value"><input type="text" class="form-control form-control-sm" @bind="_accountName" /></div>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-primary btn-sm" @onclick="SaveAsync" disabled="@_loading">Save</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="CancelEdit">Cancel</button>
                </div>
            }
            else
            {
                <div class="props-grid">
                    <span class="prop-label">Account Name</span>
                    <span class="prop-value">@_accountName</span>
                </div>
            }
        </div>

        <div class="section-divider mb-4">
            <div class="section-divider-label">
                Invitations
                <PermissionView Action="AuthAction.Update" Resource="@PermissionConstants.ACCOUNT_RESOURCE_TYPE" ResourceIds="new[] { Id }">
                    <button class="btn btn-primary btn-sm" @onclick="ShowCreateInvitation" disabled="@_loading">Create Invitation</button>
                </PermissionView>
            </div>
            <table class="table table-sm table-hover mb-0">
                <thead>
                    <tr>
                        <th class="@GetInvSortClass(nameof(Invitation.Email))" @onclick="() => CycleInvSortAsync(nameof(Invitation.Email))">
                            <span>Email <i class="bi @(GetInvSortIcon(nameof(Invitation.Email))) sort-icon"></i></span>
                            <div class="th-search" @onclick:stopPropagation="true">
                                <input type="text" class="form-control"
                                       placeholder="Search..."
                                       @bind="_invSearchEmail"
                                       @bind:event="oninput"
                                       @bind:after="OnInvSearchChangedAsync" />
                            </div>
                        </th>
                        <th class="@GetInvSortClass(nameof(Invitation.Description))" @onclick="() => CycleInvSortAsync(nameof(Invitation.Description))">
                            <span>Description <i class="bi @(GetInvSortIcon(nameof(Invitation.Description))) sort-icon"></i></span>
                            <div class="th-search" @onclick:stopPropagation="true">
                                <input type="text" class="form-control"
                                       placeholder="Search..."
                                       @bind="_invSearchDescription"
                                       @bind:event="oninput"
                                       @bind:after="OnInvSearchChangedAsync" />
                            </div>
                        </th>
                        <th>
                            <span>Status</span>
                            <div class="th-search" @onclick:stopPropagation="true">
                                <select class="form-select form-select-sm" @bind="_invStatusFilter" @bind:after="OnInvStatusChangedAsync">
                                    <option value="">All</option>
                                    @foreach (var status in Enum.GetValues<InvitationStatus>())
                                    {
                                        <option value="@status">@status</option>
                                    }
                                </select>
                            </div>
                        </th>
                        <th class="@GetInvSortClass(nameof(Invitation.CreatedUtc))" @onclick="() => CycleInvSortAsync(nameof(Invitation.CreatedUtc))">
                            <span>Created <i class="bi @(GetInvSortIcon(nameof(Invitation.CreatedUtc))) sort-icon"></i></span>
                        </th>
                        <th class="@GetInvSortClass(nameof(Invitation.ExpiresUtc))" @onclick="() => CycleInvSortAsync(nameof(Invitation.ExpiresUtc))">
                            <span>Expires <i class="bi @(GetInvSortIcon(nameof(Invitation.ExpiresUtc))) sort-icon"></i></span>
                        </th>
                        <th class="table-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_invitations.Count == 0)
                    {
                        <tr><td colspan="6" class="text-muted text-center">No invitations</td></tr>
                    }
                    @foreach (var inv in _invitations)
                    {
                        <tr>
                            <td>@inv.Email</td>
                            <td>@(inv.Description ?? "")</td>
                            <td>
                                @if (inv.IsAccepted)
                                {
                                    <span class="badge bg-info">Accepted</span>
                                }
                                else if (inv.IsRevoked)
                                {
                                    <span class="badge bg-danger">Revoked</span>
                                }
                                else if (inv.IsExpired(DateTime.UtcNow))
                                {
                                    <span class="badge bg-secondary">Expired</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Pending</span>
                                }
                            </td>
                            <td><small>@inv.CreatedUtc.ToString("yyyy-MM-dd HH:mm")</small></td>
                            <td><small>@inv.ExpiresUtc.ToString("yyyy-MM-dd HH:mm")</small></td>
                            <td class="table-actions">
                                @if (inv.IsPending(DateTime.UtcNow))
                                {
                                    <PermissionView Action="AuthAction.Update" Resource="@PermissionConstants.ACCOUNT_RESOURCE_TYPE" ResourceIds="new[] { Id }">
                                        <button class="icon-btn text-danger" @onclick="() => ConfirmRevokeInvitation(inv.Id, inv.Email)" title="Revoke"><i class="bi bi-x-circle"></i></button>
                                    </PermissionView>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <Pagination Skip="_invitationsSkip" Take="@InvitationPageSize" TotalCount="@_invitationsTotalCount"
                        OnPageChanged="OnInvitationPageChangedAsync" />
        </div>

        <div class="section-divider mb-4">
            <div class="section-divider-label">
                Users
            </div>
            <table class="table table-sm table-hover mb-0">
                <thead><tr><th>Name</th><th class="table-actions">Actions</th></tr></thead>
                <tbody>
                    @if (_users.Count == 0)
                    {
                        <tr><td colspan="2" class="text-muted text-center">No users</td></tr>
                    }
                    @foreach (var user in PagedUsers)
                    {
                        <tr>
                            <td>
                                @user.Name
                                <br /><small class="guid-text">@user.Id</small>
                            </td>
                            <td class="table-actions">
                                <a href="@AppRoutes.Users/@user.Id" class="icon-btn text-primary" title="View"><i class="bi bi-eye"></i></a>
                                <PermissionView Action="AuthAction.Update" Resource="@PermissionConstants.ACCOUNT_RESOURCE_TYPE" ResourceIds="new[] { Id }">
                                    <button class="icon-btn text-danger" @onclick="() => ConfirmRemoveUser(user.Id, user.Name)" title="Remove"><i class="bi bi-trash"></i></button>
                                </PermissionView>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <Pagination Skip="_usersSkip" Take="@RelationPageSize" TotalCount="@UsersTotalCount"
                        OnPageChanged="newSkip => { _usersSkip = newSkip; StateHasChanged(); }" />
        </div>

        <PermissionView Action="AuthAction.Read" Resource="@PermissionConstants.ACCOUNT_RESOURCE_TYPE" ResourceIds="new[] { Id }">
            <div class="section-divider mb-4">
                <div class="section-divider-label">Encryption &amp; Signing</div>
                <ul class="nav nav-tabs">
                    <li class="nav-item">
                        <button class="nav-link @(_activeKeyTab == 0 ? "active" : "")" @onclick="() => _activeKeyTab = 0">
                            <i class="bi bi-key me-1"></i>Symmetric Encryption
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(_activeKeyTab == 1 ? "active" : "")" @onclick="() => _activeKeyTab = 1">
                            <i class="bi bi-shield-lock me-1"></i>Asymmetric Encryption
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(_activeKeyTab == 2 ? "active" : "")" @onclick="() => _activeKeyTab = 2">
                            <i class="bi bi-pen me-1"></i>Digital Signature
                        </button>
                    </li>
                </ul>
                <div class="tab-content pt-3">
                    @if (_activeKeyTab == 0)
                    {
                        @if (_symProvider != null)
                        {
                            <div class="mb-3">
                                <span class="badge bg-secondary">@_symProvider.ProviderName</span>
                                <small class="text-muted ms-2">@_symProvider.ProviderDescription</small>
                            </div>
                        }
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Input</label>
                            <textarea class="form-control form-control-sm" rows="2" @bind="_symInput"
                                      placeholder="Plaintext to encrypt, or ciphertext to decrypt"></textarea>
                        </div>
                        <div class="d-flex gap-2 mb-3">
                            <button class="btn btn-primary btn-sm" @onclick="SymEncryptAsync" disabled="@(_loading || string.IsNullOrWhiteSpace(_symInput))">Encrypt</button>
                            <button class="btn btn-outline-primary btn-sm" @onclick="SymDecryptAsync" disabled="@(_loading || string.IsNullOrWhiteSpace(_symInput))">Decrypt</button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="SymReEncryptAsync" disabled="@(_loading || string.IsNullOrWhiteSpace(_symInput))">Re-encrypt</button>
                        </div>
                        @if (_symOutput != null)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Output</label>
                                <div class="d-flex align-items-start gap-1">
                                    <textarea class="form-control form-control-sm font-monospace flex-grow-1" rows="1" style="field-sizing: content; resize: none;" onfocus="this.select()" readonly>@_symOutput</textarea>
                                    <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="CopySymOutputAsync" title="Copy">
                                        <i class="bi @(_symOutputCopied ? "bi-check text-success" : "bi-copy")"></i>
                                    </button>
                                </div>
                            </div>
                        }
                        @if (_symError != null)
                        {
                            <div class="alert alert-danger py-2">@_symError</div>
                        }
                    }
                    else if (_activeKeyTab == 1)
                    {
                        @if (_asymProvider != null)
                        {
                            <div class="mb-3">
                                <span class="badge bg-secondary">@_asymProvider.ProviderName</span>
                                <small class="text-muted ms-2">@_asymProvider.ProviderDescription</small>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Public Key</label>
                                <div class="d-flex align-items-start gap-1">
                                    <textarea class="form-control form-control-sm font-monospace flex-grow-1" rows="1" style="field-sizing: content; resize: none;" onfocus="this.select()" readonly>@_asymProvider.PublicKey</textarea>
                                    <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="CopyAsymPublicKeyAsync" title="Copy">
                                        <i class="bi @(_asymPublicKeyCopied ? "bi-check text-success" : "bi-copy")"></i>
                                    </button>
                                </div>
                            </div>
                        }
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Input</label>
                            <textarea class="form-control form-control-sm" rows="2" @bind="_asymInput"
                                      placeholder="Plaintext to encrypt, or ciphertext to decrypt"></textarea>
                        </div>
                        <div class="d-flex gap-2 mb-3">
                            <button class="btn btn-primary btn-sm" @onclick="AsymEncryptAsync" disabled="@(_loading || string.IsNullOrWhiteSpace(_asymInput))">Encrypt</button>
                            <button class="btn btn-outline-primary btn-sm" @onclick="AsymDecryptAsync" disabled="@(_loading || string.IsNullOrWhiteSpace(_asymInput))">Decrypt</button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="AsymReEncryptAsync" disabled="@(_loading || string.IsNullOrWhiteSpace(_asymInput))">Re-encrypt</button>
                        </div>
                        @if (_asymOutput != null)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Output</label>
                                <div class="d-flex align-items-start gap-1">
                                    <textarea class="form-control form-control-sm font-monospace flex-grow-1" rows="1" style="field-sizing: content; resize: none;" onfocus="this.select()" readonly>@_asymOutput</textarea>
                                    <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="CopyAsymOutputAsync" title="Copy">
                                        <i class="bi @(_asymOutputCopied ? "bi-check text-success" : "bi-copy")"></i>
                                    </button>
                                </div>
                            </div>
                        }
                        @if (_asymError != null)
                        {
                            <div class="alert alert-danger py-2">@_asymError</div>
                        }
                    }
                    else
                    {
                        @if (_sigProvider != null)
                        {
                            <div class="mb-3">
                                <span class="badge bg-secondary">@_sigProvider.ProviderName</span>
                                <small class="text-muted ms-2">@_sigProvider.ProviderDescription</small>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Public Key</label>
                                <div class="d-flex align-items-start gap-1">
                                    <textarea class="form-control form-control-sm font-monospace flex-grow-1" rows="1" style="field-sizing: content; resize: none;" onfocus="this.select()" readonly>@_sigProvider.PublicKey</textarea>
                                    <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="CopySigPublicKeyAsync" title="Copy">
                                        <i class="bi @(_sigPublicKeyCopied ? "bi-check text-success" : "bi-copy")"></i>
                                    </button>
                                </div>
                            </div>
                        }
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Payload</label>
                            <textarea class="form-control form-control-sm" rows="2" @bind="_sigPayload"
                                      placeholder="Text to sign or verify"></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Signature</label>
                            <textarea class="form-control form-control-sm font-monospace" rows="2" @bind="_sigSignature"
                                      placeholder="Signature value (populated by Sign, required for Verify)"></textarea>
                        </div>
                        <div class="d-flex gap-2 mb-3">
                            <button class="btn btn-primary btn-sm" @onclick="SignAsync" disabled="@(_loading || string.IsNullOrWhiteSpace(_sigPayload))">Sign</button>
                            <button class="btn btn-outline-primary btn-sm" @onclick="VerifyAsync"
                                    disabled="@(_loading || string.IsNullOrWhiteSpace(_sigPayload) || string.IsNullOrWhiteSpace(_sigSignature))">Verify</button>
                        </div>
                        @if (_sigResult != null)
                        {
                            <div class="alert @(_sigResultIsValid == true ? "alert-success" : _sigResultIsValid == false ? "alert-danger" : "alert-info") py-2">@_sigResult</div>
                        }
                        @if (_sigError != null)
                        {
                            <div class="alert alert-danger py-2">@_sigError</div>
                        }
                    }
                </div>
            </div>
        </PermissionView>

        <EffectivePermissionsPanel Permissions="_effectivePermissions" UseCard="false" />

    </div>
}

<ConfirmModal @ref="_removeUserModal" Title="Remove User" Message="@_confirmMessage" ConfirmText="Remove" OnConfirm="RemoveUserAsync" />
<ConfirmModal @ref="_deleteModal" Title="Delete Account" Message="@($"Permanently delete account '{_accountName}'? This cannot be undone.")" ConfirmText="Delete" OnConfirm="DeleteAsync" />
<ConfirmModal @ref="_revokeInvitationModal" Title="Revoke Invitation" Message="@_confirmMessage" ConfirmText="Revoke" OnConfirm="RevokeInvitationAsync" />

<FormModal @ref="_createInvitationModal" Title="Create Invitation" ConfirmText="Create" OnConfirm="CreateInvitationAsync">
    <div class="mb-3">
        <label class="form-label">Email <span class="text-danger">*</span></label>
        <input type="email" class="form-control form-control-sm" @bind="_inviteEmail" placeholder="recipient@example.com" />
    </div>
    <div class="mb-3">
        <label class="form-label">Description</label>
        <input type="text" class="form-control form-control-sm" @bind="_inviteDescription" placeholder="Optional note" maxlength="200" />
    </div>
    <div class="mb-3">
        <label class="form-label">Expires In</label>
        <select class="form-select form-select-sm" @bind="_inviteExpirySeconds">
            <option value="3600">1 hour</option>
            <option value="86400">1 day</option>
            <option value="604800">7 days</option>
            <option value="2592000">30 days</option>
        </select>
    </div>
</FormModal>

@if (_createdToken != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);" @onclick="() => _createdToken = null">
        <div class="modal-dialog" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Invitation Created</h5>
                    <button type="button" class="btn-close" @onclick="() => _createdToken = null"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-success mb-0">
                        <strong>Copy this token</strong> — it will not be shown again.
                        <div class="input-group mt-2">
                            <input type="text" class="form-control form-control-sm font-monospace" readonly value="@_createdToken" onclick="this.select()" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary btn-sm" @onclick="CopyTokenAsync">
                        @(_tokenCopied ? "Copied!" : "Copy to Clipboard")
                    </button>
                    <button type="button" class="btn btn-secondary btn-sm" @onclick="() => { _createdToken = null; _tokenCopied = false; }">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string? _accountName;
    private string? _originalAccountName;
    private bool _isEditing;
    private List<ChildRef> _users = [];
    private List<EffectivePermission>? _effectivePermissions;
    private ConfirmModal _removeUserModal = null!;
    private ConfirmModal _deleteModal = null!;
    private ConfirmModal _revokeInvitationModal = null!;
    private FormModal _createInvitationModal = null!;

    private List<Invitation> _invitations = [];
    private int _invitationsTotalCount;
    private string _invSearchEmail = string.Empty;
    private string _invSearchDescription = string.Empty;
    private InvitationStatus? _invStatusFilter;
    private string? _invSortColumn;
    private SortDirection? _invSortDirection;
    private string? _inviteEmail;
    private string? _inviteDescription;
    private int _inviteExpirySeconds = InvitationConstants.DEFAULT_EXPIRY_SECONDS;
    private string? _createdToken;
    private bool _tokenCopied;
    private bool _symOutputCopied;
    private bool _asymPublicKeyCopied;
    private bool _asymOutputCopied;
    private bool _sigPublicKeyCopied;
    private CancellationTokenSource? _invSearchCts;

    private int _usersSkip;
    private int _invitationsSkip;
    private const int RelationPageSize = 10;
    private const int InvitationPageSize = 10;
    private List<ChildRef> PagedUsers => _users.Skip(_usersSkip).Take(RelationPageSize).ToList();
    private int UsersTotalCount => _users.Count;

    // Key operations state
    private int _activeKeyTab;
    private IIamSymmetricEncryptionProvider? _symProvider;
    private IIamAsymmetricEncryptionProvider? _asymProvider;
    private IIamAsymmetricSignatureProvider? _sigProvider;
    private string _symInput = string.Empty;
    private string? _symOutput;
    private string? _symError;
    private string _asymInput = string.Empty;
    private string? _asymOutput;
    private string? _asymError;
    private string _sigPayload = string.Empty;
    private string _sigSignature = string.Empty;
    private string? _sigResult;
    private bool? _sigResultIsValid;
    private string? _sigError;

    protected override async Task LoadCoreAsync()
    {
        var result = await RetrievalService.GetAccountAsync(Id, hydrate: true);
        if (result.ResultCode == RetrieveResultCode.Success && result.Item != null)
        {
            _accountName = result.Item.AccountName;
            _users = result.Item.Users ?? [];
            _effectivePermissions = result.EffectivePermissions;
        }
        else
        {
            NavigationManager.NavigateTo(AppRoutes.Dashboard);
            return;
        }

        await LoadInvitationsAsync();
        await GetSymProviderAsync();
        await GetAsymProviderAsync();
        await GetSigProviderAsync();
    }

    private async Task LoadInvitationsAsync()
    {
        var filterBuilder = Filter.For<Invitation>();
        var hasFilter = false;
        if (!string.IsNullOrWhiteSpace(_invSearchEmail))
        {
            filterBuilder.Where(i => i.Email, StringFilter.Contains(_invSearchEmail.Trim()));
            hasFilter = true;
        }
        if (!string.IsNullOrWhiteSpace(_invSearchDescription))
        {
            filterBuilder.Where(i => i.Description!, StringFilter.Contains(_invSearchDescription.Trim()));
            hasFilter = true;
        }
        var filter = hasFilter ? filterBuilder : null;

        OrderBuilder<Invitation>? order = null;
        if (_invSortColumn != null && _invSortDirection != null)
        {
            order = _invSortColumn switch
            {
                nameof(Invitation.Email) => Order.For<Invitation>().By(i => i.Email, _invSortDirection.Value),
                nameof(Invitation.Description) => Order.For<Invitation>().By(i => i.Description, _invSortDirection.Value),
                nameof(Invitation.CreatedUtc) => Order.For<Invitation>().By(i => i.CreatedUtc, _invSortDirection.Value),
                nameof(Invitation.ExpiresUtc) => Order.For<Invitation>().By(i => i.ExpiresUtc, _invSortDirection.Value),
                _ => null
            };
        }

        var invResult = await RegistrationService.ListInvitationsAsync(
            new ListInvitationsRequest(Id, filter, order, _invitationsSkip, InvitationPageSize, _invStatusFilter)
        );
        if (invResult.ResultCode == RetrieveResultCode.Success && invResult.Data != null)
        {
            _invitations = invResult.Data.Items.ToList();
            _invitationsTotalCount = invResult.Data.TotalCount;
        }
    }

    private async Task OnInvitationPageChangedAsync(int newSkip)
    {
        _invitationsSkip = newSkip;
        await LoadInvitationsAsync();
        StateHasChanged();
    }

    private async Task OnInvSearchChangedAsync()
    {
        _invSearchCts?.Cancel();
        _invSearchCts?.Dispose();
        _invSearchCts = new CancellationTokenSource();
        var token = _invSearchCts.Token;

        try
        {
            await Task.Delay(300, token);
            _invitationsSkip = 0;
            await LoadInvitationsAsync();
            StateHasChanged();
        }
        catch (TaskCanceledException) { }
    }

    private async Task OnInvStatusChangedAsync()
    {
        _invitationsSkip = 0;
        await LoadInvitationsAsync();
        StateHasChanged();
    }

    private async Task CycleInvSortAsync(string column)
    {
        if (_invSortColumn != column)
        {
            _invSortColumn = column;
            _invSortDirection = SortDirection.Ascending;
        }
        else if (_invSortDirection == SortDirection.Ascending)
        {
            _invSortDirection = SortDirection.Descending;
        }
        else
        {
            _invSortColumn = null;
            _invSortDirection = null;
        }
        _invitationsSkip = 0;
        await LoadInvitationsAsync();
        StateHasChanged();
    }

    private string GetInvSortIcon(string column)
    {
        if (_invSortColumn != column) return "bi-chevron-expand";
        return _invSortDirection == SortDirection.Ascending ? "bi-chevron-up" : "bi-chevron-down";
    }

    private string GetInvSortClass(string column)
    {
        return _invSortColumn == column ? "sortable active" : "sortable";
    }

    private void StartEdit()
    {
        _originalAccountName = _accountName;
        _isEditing = true;
    }

    private void CancelEdit()
    {
        _accountName = _originalAccountName;
        _isEditing = false;
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_accountName)) return;
        await ExecuteSafeAsync(async () =>
        {
            var result = await ModificationService.ModifyAccountAsync(new UpdateAccountRequest(Id, _accountName));
            SetResultMessage(result.ResultCode == ModifyResultCode.Success, "Saved.", result.Message);
            if (result.ResultCode == ModifyResultCode.Success)
            {
                _isEditing = false;
                AccountDisplayState.UpdateAccountName(_accountName!);
            }
        });
    }

    private void ConfirmDelete() => _deleteModal.Show();

    private async Task DeleteAsync()
    {
        await ExecuteSafeAsync(async () =>
        {
            var result = await DeregistrationService.DeregisterAccountAsync();
            if (result.ResultCode == DeregisterAccountResultCode.Success)
            {
                NavigationManager.NavigateTo(AppRoutes.Dashboard, forceLoad: true);
                return;
            }
            SetResultMessage(false, string.Empty, result.Message);
        });
    }

    private void ConfirmRemoveUser(Guid userId, string name) => ShowConfirmation(_removeUserModal, userId, $"Remove user '{name}'?");

    private async Task RemoveUserAsync()
    {
        await ExecuteSafeAsync(async () =>
        {
            var removedUserId = _confirmItemId;
            var result = await DeregistrationService.DeregisterUserFromAccountAsync(new DeregisterUserFromAccountRequest(removedUserId));
            if (result.ResultCode == DeregisterUserFromAccountResultCode.Success
                && removedUserId == UserContext?.User.Id)
            {
                NavigationManager.NavigateTo(AppRoutes.SelectAccount, forceLoad: true);
                return;
            }
            SetResultMessage(result.ResultCode == DeregisterUserFromAccountResultCode.Success, "User removed.", result.Message ?? "Failed.");
            await ReloadAsync();
        });
    }

    private void ShowCreateInvitation()
    {
        _inviteEmail = string.Empty;
        _inviteDescription = string.Empty;
        _inviteExpirySeconds = InvitationConstants.DEFAULT_EXPIRY_SECONDS;
        _createdToken = null;
        _tokenCopied = false;
        _createInvitationModal.Show();
    }

    private async Task CreateInvitationAsync()
    {
        await ExecuteSafeAsync(async () =>
        {
            var request = new CreateInvitationRequest(Id, _inviteEmail!, _inviteDescription, _inviteExpirySeconds);
            var result = await RegistrationService.CreateInvitationAsync(request);
            if (result.ResultCode == CreateInvitationResultCode.Success)
            {
                _createdToken = result.Token;
                SetResultMessage(true, "Invitation created.");
                await ReloadAsync();
            }
            else if (result.ResultCode == CreateInvitationResultCode.UserAlreadyInAccountError)
            {
                SetResultMessage(false, string.Empty, $"{result.Message} User ID: {result.ExistingUserId}");
            }
            else
            {
                SetResultMessage(false, string.Empty, result.Message);
            }
        });
    }

    private async Task CopyTokenAsync()
    {
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", _createdToken);
        _tokenCopied = true;
        StateHasChanged();
        await Task.Delay(1500);
        _tokenCopied = false;
        StateHasChanged();
    }

    private async Task CopySymOutputAsync() => await CopyWithFeedbackAsync(_symOutput, v => _symOutputCopied = v);

    private async Task CopyAsymPublicKeyAsync() => await CopyWithFeedbackAsync(_asymProvider?.PublicKey, v => _asymPublicKeyCopied = v);

    private async Task CopyAsymOutputAsync() => await CopyWithFeedbackAsync(_asymOutput, v => _asymOutputCopied = v);

    private async Task CopySigPublicKeyAsync() => await CopyWithFeedbackAsync(_sigProvider?.PublicKey, v => _sigPublicKeyCopied = v);

    private async Task CopyWithFeedbackAsync(string? text, Action<bool> setFlag)
    {
        if (string.IsNullOrEmpty(text)) return;
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", text);
        setFlag(true);
        StateHasChanged();
        await Task.Delay(1500);
        setFlag(false);
        StateHasChanged();
    }

