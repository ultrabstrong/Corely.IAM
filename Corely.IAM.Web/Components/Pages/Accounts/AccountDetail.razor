    private async Task<IIamSymmetricEncryptionProvider?> GetSymProviderAsync()
    {
        if (_symProvider != null)
            return _symProvider;

        var result = await RetrievalService.GetAccountSymmetricEncryptionProviderAsync(Id);
        if (result.ResultCode == RetrieveResultCode.Success && result.Item != null)
        {
            _symProvider = result.Item;
            return _symProvider;
        }
        _symError = result.Message ?? "Failed to load symmetric encryption provider.";
        return null;
    }

    private async Task SymEncryptAsync()
    {
        _symOutput = null;
        _symError = null;
        await ExecuteSafeAsync(async () =>
        {
            var provider = await GetSymProviderAsync();
            if (provider != null)
                _symOutput = provider.Encrypt(_symInput);
        });
    }

    private async Task SymDecryptAsync()
    {
        _symOutput = null;
        _symError = null;
        await ExecuteSafeAsync(async () =>
        {
            var provider = await GetSymProviderAsync();
            if (provider == null)
                return;

            try
            {
                _symOutput = provider.Decrypt(_symInput);
            }
            catch (Exception ex)
            {
                _symError = $"Decryption failed: {ex.Message}";
            }
        });
    }

    private async Task SymReEncryptAsync()
    {
        _symOutput = null;
        _symError = null;
        await ExecuteSafeAsync(async () =>
        {
            var provider = await GetSymProviderAsync();
            if (provider == null)
                return;

            try
            {
                _symOutput = provider.ReEncrypt(_symInput);
            }
            catch (Exception ex)
            {
                _symError = $"Re-encryption failed: {ex.Message}";
            }
        });
    }

