    private async Task<IIamAsymmetricSignatureProvider?> GetSigProviderAsync()
    {
        if (_sigProvider != null)
            return _sigProvider;

        var result = await RetrievalService.GetAccountAsymmetricSignatureProviderAsync(Id);
        if (result.ResultCode == RetrieveResultCode.Success && result.Item != null)
        {
            _sigProvider = result.Item;
            return _sigProvider;
        }
        _sigError = result.Message ?? "Failed to load signature provider.";
        return null;
    }

    private async Task SignAsync()
    {
        _sigResult = null;
        _sigResultIsValid = null;
        _sigError = null;
        await ExecuteSafeAsync(async () =>
        {
            var provider = await GetSigProviderAsync();
            if (provider != null)
            {
                _sigSignature = provider.Sign(_sigPayload);
                _sigResult = "Payload signed. Signature populated below.";
            }
        });
    }

    private async Task VerifyAsync()
    {
        _sigResult = null;
        _sigResultIsValid = null;
        _sigError = null;
        await ExecuteSafeAsync(async () =>
        {
            var provider = await GetSigProviderAsync();
            if (provider == null)
                return;

            try
            {
                var isValid = provider.Verify(_sigPayload, _sigSignature);
                _sigResultIsValid = isValid;
                _sigResult = isValid ? "Signature is valid." : "Signature is invalid.";
            }
            catch (Exception ex)
            {
                _sigError = $"Verification failed: {ex.Message}";
            }
        });
    }
