@page "/profile"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inherits EntityPageBase
@inject IRetrievalService RetrievalService
@inject IRegistrationService RegistrationService
@inject IModificationService ModificationService
@inject IDeregistrationService DeregistrationService
@inject IJSRuntime JSRuntime

<PageTitle>Profile - Corely IAM</PageTitle>

<div class="management-header">
    <h1><i class="bi bi-person me-2"></i>Profile</h1>
    @if (UserContext?.CurrentAccount != null)
    {
        <a href="@AppRoutes.Dashboard" class="btn btn-outline-secondary btn-sm">Dashboard</a>
    }
</div>

<Alert Message="@_message" Type="@_messageType" OnDismissed="() => _message = null" />

@if (_loading && _username == null)
{
    <LoadingSpinner />
}
else
{
    @if (_isEditing)
    {
        <div class="props-grid mb-3">
            <span class="prop-label">Username</span>
            <div class="prop-value"><input type="text" class="form-control form-control-sm" @bind="_username" /></div>
            <span class="prop-label">Email</span>
            <div class="prop-value"><input type="email" class="form-control form-control-sm" @bind="_email" /></div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary btn-sm" @onclick="SaveAsync" disabled="@_loading">Save</button>
            <button class="btn btn-outline-secondary btn-sm" @onclick="CancelEdit">Cancel</button>
        </div>
    }
    else
    {
        <div class="props-grid mb-3">
            <span class="prop-label">Username</span>
            <span class="prop-value">@_username</span>
            <span class="prop-label">Email</span>
            <span class="prop-value">@_email</span>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary btn-sm" @onclick="StartEdit">Edit</button>
            <button class="btn btn-outline-danger btn-sm" @onclick="() => _deleteModal.Show()" disabled="@_loading">Delete Account</button>
        </div>
    }

    @if (UserContext?.AvailableAccounts.Count > 0)
    {
        <div class="section-divider mb-4 mt-4">
            <div class="section-divider-label">Accounts</div>
            <table class="table table-sm table-hover mb-0">
                <thead><tr><th>Name</th><th class="table-actions">Actions</th></tr></thead>
                <tbody>
                    @foreach (var account in PagedAccounts)
                    {
                        <tr>
                            <td>
                                @account.AccountName
                                <br /><small class="guid-text">@account.Id</small>
                            </td>
                            <td class="table-actions">
                                <a href="@AppRoutes.Accounts/@account.Id" class="icon-btn text-primary" title="View"><i class="bi bi-eye"></i></a>
                                <button class="icon-btn text-danger" @onclick="() => ConfirmLeaveAccount(account.Id, account.AccountName)" title="Leave"><i class="bi bi-box-arrow-right"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <Pagination Skip="_accountsSkip" Take="@AccountPageSize" TotalCount="@AccountsTotalCount"
                        OnPageChanged="newSkip => { _accountsSkip = newSkip; StateHasChanged(); }" />
        </div>
    }

    <div class="section-divider mb-4 mt-4">
        <div class="section-divider-label">Two-Factor Authentication</div>
        @if (_totpSetupPhase)
        {
            <div class="alert alert-info">
                <strong>Setup:</strong> Scan the QR code with your authenticator app, or enter the secret manually.
                <div class="mt-2 d-flex justify-content-center">
                    <div id="totp-qrcode"></div>
                </div>
                <div class="mt-2 text-center"><small>Secret: <code>@_totpSecret</code></small></div>
            </div>
            <div class="alert alert-warning">
                <strong>Recovery Codes:</strong> Save these codes in a safe place. Each can only be used once.
                <div class="mt-2" style="font-family: monospace;">
                    @foreach (var rc in _totpRecoveryCodes)
                    {
                        <div>@rc</div>
                    }
                </div>
            </div>
            <div class="d-flex gap-2 align-items-center">
                <input type="text" class="form-control form-control-sm" style="max-width: 200px;"
                       @bind="_confirmCode" placeholder="Enter code to confirm" />
                <button class="btn btn-primary btn-sm" @onclick="ConfirmTotpAsync" disabled="@_loading">Confirm</button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="CancelTotpSetup">Cancel</button>
            </div>
        }
        else if (_totpEnabled)
        {
            <p class="text-success mb-2"><i class="bi bi-shield-check me-1"></i>Enabled (@_totpRemainingCodes remaining recovery codes)</p>
            @if (_regeneratedCodes != null)
            {
                <div class="alert alert-warning">
                    <strong>New Recovery Codes:</strong> Save these codes now. They won't be shown again.
                    <div class="mt-2" style="font-family: monospace;">
                        @foreach (var rc in _regeneratedCodes)
                        {
                            <div>@rc</div>
                        }
                    </div>
                </div>
            }
            @if (_showDisableInput)
            {
                <div class="d-flex gap-2 align-items-center mb-2">
                    <input type="text" class="form-control form-control-sm" style="max-width: 200px;"
                           @bind="_disableCode" placeholder="Enter current TOTP code" />
                    <button class="btn btn-danger btn-sm" @onclick="DisableTotpAsync" disabled="@_loading">Confirm Disable</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => _showDisableInput = false">Cancel</button>
                </div>
            }
            else
            {
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-warning btn-sm" @onclick="RegenerateCodesAsync" disabled="@_loading">
                        Regenerate Recovery Codes
                    </button>
                    <button class="btn btn-outline-danger btn-sm" @onclick="() => _showDisableInput = true" disabled="@_loading">
                        Disable
                    </button>
                </div>
            }
        }
        else
        {
            <p class="text-muted mb-2">Protect your account with TOTP-based two-factor authentication.</p>
            <button class="btn btn-outline-primary btn-sm" @onclick="EnableTotpAsync" disabled="@_loading">
                Enable Two-Factor Authentication
            </button>
        }
    </div>

    <div class="section-divider mb-4 mt-4">
        <div class="section-divider-label">Linked Accounts</div>
        @if (_hasGoogleAuth)
        {
            <div class="props-grid mb-2">
                <span class="prop-label">Google</span>
                <span class="prop-value">@_googleEmail <i class="bi bi-check-circle text-success"></i></span>
            </div>
            <button class="btn btn-outline-danger btn-sm" @onclick="() => _unlinkGoogleModal.Show()" disabled="@_loading">
                Unlink Google Account
            </button>
        }
        else
        {
            <p class="text-muted mb-2">No Google account linked. Use the Google Sign-In flow to link an account.</p>
        }
    </div>

    <EncryptionSigningPanel SymProvider="_symProvider" AsymProvider="_asymProvider" SigProvider="_sigProvider" />
}

<ConfirmModal @ref="_deleteModal"
              Title="Delete Account"
              Message="@($"Permanently delete your account '{_username}'? This cannot be undone.")"
              ConfirmText="Delete"
              OnConfirm="DeleteAsync" />
<ConfirmModal @ref="_leaveAccountModal"
              Title="Leave Account"
              Message="@_leaveAccountMessage"
              ConfirmText="Leave"
              OnConfirm="LeaveAccountAsync" />
<ConfirmModal @ref="_unlinkGoogleModal"
              Title="Unlink Google Account"
              Message="Remove your linked Google account? You will no longer be able to sign in with Google."
              ConfirmText="Unlink"
              OnConfirm="UnlinkGoogleAsync" />

@code {
    private string? _username;
    private string? _email;
    private string? _originalUsername;
    private string? _originalEmail;
    private bool _isEditing;
    private ConfirmModal _deleteModal = null!;
    private ConfirmModal _leaveAccountModal = null!;
    private Guid _leaveAccountId;
    private string _leaveAccountMessage = "";
    private int _accountsSkip;
    private const int AccountPageSize = 10;
    private List<Account> PagedAccounts => (UserContext?.AvailableAccounts ?? []).Skip(_accountsSkip).Take(AccountPageSize).ToList();
    private int AccountsTotalCount => UserContext?.AvailableAccounts.Count ?? 0;

    private IIamSymmetricEncryptionProvider? _symProvider;
    private IIamAsymmetricEncryptionProvider? _asymProvider;
    private IIamAsymmetricSignatureProvider? _sigProvider;

    // TOTP state
    private bool _totpEnabled;
    private bool _totpSetupPhase;
    private string? _totpSecret;
    private string? _totpSetupUri;
    private string[] _totpRecoveryCodes = [];
    private string _confirmCode = "";
    private string _disableCode = "";
    private bool _showDisableInput;
    private string[]? _regeneratedCodes;
    private int _totpRemainingCodes;
    private bool _pendingQrRender;

    // Linked accounts state
    private bool _hasBasicAuth;
    private bool _hasGoogleAuth;
    private string? _googleEmail;
    private ConfirmModal _unlinkGoogleModal = null!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingQrRender && !string.IsNullOrWhiteSpace(_totpSetupUri))
        {
            _pendingQrRender = false;
            await JSRuntime.InvokeVoidAsync("qrCodeInterop.generate", "totp-qrcode", _totpSetupUri, 200);
        }
    }

    protected override async Task LoadCoreAsync()
    {
        var result = await RetrievalService.GetUserAsync(UserContext!.User!.Id, hydrate: false);
        if (result.ResultCode == RetrieveResultCode.Success && result.Item != null)
        {
            _username = result.Item.Username;
            _email = result.Item.Email;
        }
        else
        {
            NavigationManager.NavigateTo(AppRoutes.SignIn, forceLoad: true);
            return;
        }

        await LoadKeyProvidersAsync();
        await LoadTotpStatusAsync();
        await LoadAuthMethodsAsync();
    }

    private async Task LoadKeyProvidersAsync()
    {
        var symResult = await RetrievalService.GetUserSymmetricEncryptionProviderAsync();
        if (symResult.ResultCode == RetrieveResultCode.Success)
            _symProvider = symResult.Item;

        var asymResult = await RetrievalService.GetUserAsymmetricEncryptionProviderAsync();
        if (asymResult.ResultCode == RetrieveResultCode.Success)
            _asymProvider = asymResult.Item;

        var sigResult = await RetrievalService.GetUserAsymmetricSignatureProviderAsync();
        if (sigResult.ResultCode == RetrieveResultCode.Success)
            _sigProvider = sigResult.Item;
    }

    private void StartEdit()
    {
        _originalUsername = _username;
        _originalEmail = _email;
        _isEditing = true;
    }

    private void CancelEdit()
    {
        _username = _originalUsername;
        _email = _originalEmail;
        _isEditing = false;
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_email)) return;
        await ExecuteSafeAsync(async () =>
        {
            var result = await ModificationService.ModifyUserAsync(
                new UpdateUserRequest(UserContext!.User!.Id, _username, _email)
            );
            SetResultMessage(result.ResultCode == ModifyResultCode.Success, "Saved.", result.Message);
            if (result.ResultCode == ModifyResultCode.Success)
                _isEditing = false;
        });
    }

    private async Task DeleteAsync()
    {
        await ExecuteSafeAsync(async () =>
        {
            var result = await DeregistrationService.DeregisterUserAsync();
            if (result.ResultCode == DeregisterUserResultCode.Success)
            {
                NavigationManager.NavigateTo(AppRoutes.SignOut, forceLoad: true);
                return;
            }
            SetResultMessage(false, string.Empty, result.Message);
        });
    }

    private void ConfirmLeaveAccount(Guid accountId, string name)
    {
        _leaveAccountId = accountId;
        _leaveAccountMessage = $"Leave account '{name}'? You will lose access to all resources in this account.";
        _leaveAccountModal.Show();
    }

    private async Task LeaveAccountAsync()
    {
        await ExecuteSafeAsync(async () =>
        {
            var result = await DeregistrationService.LeaveAccountAsync(_leaveAccountId);
            if (result.ResultCode == DeregisterUserFromAccountResultCode.Success)
            {
                NavigationManager.NavigateTo(AppRoutes.SelectAccount, forceLoad: true);
                return;
            }
            SetResultMessage(false, string.Empty, result.Message ?? "Failed.");
        });
    }

    private async Task LoadTotpStatusAsync()
    {
        var status = await RetrievalService.GetTotpStatusAsync();
        if (status.ResultCode == TotpStatusResultCode.Success)
        {
            _totpEnabled = status.IsEnabled;
            _totpRemainingCodes = status.RemainingRecoveryCodes;
        }
    }

    private async Task LoadAuthMethodsAsync()
    {
        var methods = await RetrievalService.GetAuthMethodsAsync();
        if (methods.ResultCode == AuthMethodsResultCode.Success)
        {
            _hasBasicAuth = methods.HasBasicAuth;
            _hasGoogleAuth = methods.HasGoogleAuth;
            _googleEmail = methods.GoogleEmail;
        }
    }

    private async Task EnableTotpAsync()
    {
        await ExecuteSafeAsync(async () =>
        {
            var result = await RegistrationService.EnableTotpAsync();
            if (result.ResultCode == EnableTotpResultCode.Success)
            {
                _totpSetupPhase = true;
                _totpSecret = result.Secret;
                _totpSetupUri = result.SetupUri;
                _totpRecoveryCodes = result.RecoveryCodes ?? [];
                _regeneratedCodes = null;
                _pendingQrRender = true;
            }
            else
            {
                SetResultMessage(false, string.Empty, result.Message);
            }
        });
    }

    private async Task ConfirmTotpAsync()
    {
        if (string.IsNullOrWhiteSpace(_confirmCode)) return;
        await ExecuteSafeAsync(async () =>
        {
            var result = await RegistrationService.ConfirmTotpAsync(new ConfirmTotpRequest(_confirmCode.Trim()));
            if (result.ResultCode == ConfirmTotpResultCode.Success)
            {
                _totpSetupPhase = false;
                _totpEnabled = true;
                _confirmCode = "";
                await LoadTotpStatusAsync();
                SetResultMessage(true, "Two-factor authentication enabled.");
            }
            else
            {
                SetResultMessage(false, string.Empty, result.Message);
            }
        });
    }

    private void CancelTotpSetup()
    {
        _totpSetupPhase = false;
        _totpSecret = null;
        _totpSetupUri = null;
        _totpRecoveryCodes = [];
        _confirmCode = "";
    }

    private async Task RegenerateCodesAsync()
    {
        await ExecuteSafeAsync(async () =>
        {
            var result = await RegistrationService.RegenerateTotpRecoveryCodesAsync();
            if (result.ResultCode == RegenerateTotpRecoveryCodesResultCode.Success)
            {
                _regeneratedCodes = result.RecoveryCodes;
                await LoadTotpStatusAsync();
                SetResultMessage(true, "Recovery codes regenerated. Save them now.");
            }
            else
            {
                SetResultMessage(false, string.Empty, result.Message);
            }
        });
    }

    private async Task DisableTotpAsync()
    {
        if (string.IsNullOrWhiteSpace(_disableCode)) return;
        await ExecuteSafeAsync(async () =>
        {
            var result = await RegistrationService.DisableTotpAsync(new DisableTotpRequest(_disableCode.Trim()));
            if (result.ResultCode == DisableTotpResultCode.Success)
            {
                _totpEnabled = false;
                _showDisableInput = false;
                _disableCode = "";
                _regeneratedCodes = null;
                SetResultMessage(true, "Two-factor authentication disabled.");
            }
            else
            {
                SetResultMessage(false, string.Empty, result.Message);
            }
        });
    }

    private async Task UnlinkGoogleAsync()
    {
        await ExecuteSafeAsync(async () =>
        {
            var result = await DeregistrationService.UnlinkGoogleAuthAsync();
            if (result.ResultCode == UnlinkGoogleAuthResultCode.Success)
            {
                _hasGoogleAuth = false;
                _googleEmail = null;
                SetResultMessage(true, "Google account unlinked.");
            }
            else
            {
                SetResultMessage(false, string.Empty, result.Message);
            }
        });
    }
}
