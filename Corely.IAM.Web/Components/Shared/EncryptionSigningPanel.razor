@inject IJSRuntime JSRuntime

<div class="section-divider mb-4">
    <div class="section-divider-label">Encryption &amp; Signing</div>
    <ul class="nav nav-tabs">
        <li class="nav-item">
            <button class="nav-link @(_activeKeyTab == 0 ? "active" : "")" @onclick="() => _activeKeyTab = 0">
                <i class="bi bi-key me-1"></i>Symmetric Encryption
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(_activeKeyTab == 1 ? "active" : "")" @onclick="() => _activeKeyTab = 1">
                <i class="bi bi-shield-lock me-1"></i>Asymmetric Encryption
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(_activeKeyTab == 2 ? "active" : "")" @onclick="() => _activeKeyTab = 2">
                <i class="bi bi-pen me-1"></i>Digital Signature
            </button>
        </li>
    </ul>
    <div class="tab-content pt-3">
        @if (_activeKeyTab == 0)
        {
            @if (SymProvider != null)
            {
                <div class="mb-3">
                    <span class="badge bg-secondary">@SymProvider.ProviderName</span>
                    <small class="text-muted ms-2">@SymProvider.ProviderDescription</small>
                </div>
            }
            <div class="mb-3">
                <label class="form-label fw-semibold">Input</label>
                <textarea class="form-control form-control-sm" rows="2" @bind="_symInput"
                          placeholder="Plaintext to encrypt, or ciphertext to decrypt"></textarea>
            </div>
            <div class="d-flex gap-2 mb-3">
                <button class="btn btn-primary btn-sm" @onclick="SymEncryptAsync" disabled="@_busy">Encrypt</button>
                <button class="btn btn-outline-primary btn-sm" @onclick="SymDecryptAsync" disabled="@_busy">Decrypt</button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="SymReEncryptAsync" disabled="@_busy">Re-encrypt</button>
            </div>
            @if (_symOutput != null)
            {
                <div class="mb-3">
                    <label class="form-label fw-semibold">Output</label>
                    <div class="d-flex align-items-start gap-1">
                        <textarea class="form-control form-control-sm font-monospace flex-grow-1" rows="1" style="field-sizing: content; resize: none;" onfocus="this.select()" readonly>@_symOutput</textarea>
                        <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="CopySymOutputAsync" title="Copy">
                            <i class="bi @(_symOutputCopied ? "bi-check text-success" : "bi-copy")"></i>
                        </button>
                    </div>
                </div>
            }
            @if (_symError != null)
            {
                <div class="alert alert-danger py-2">@_symError</div>
            }
        }
        else if (_activeKeyTab == 1)
        {
            @if (AsymProvider != null)
            {
                <div class="mb-3">
                    <span class="badge bg-secondary">@AsymProvider.ProviderName</span>
                    <small class="text-muted ms-2">@AsymProvider.ProviderDescription</small>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Public Key</label>
                    <div class="d-flex align-items-start gap-1">
                        <textarea class="form-control form-control-sm font-monospace flex-grow-1" rows="1" style="field-sizing: content; resize: none;" onfocus="this.select()" readonly>@AsymProvider.PublicKey</textarea>
                        <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="CopyAsymPublicKeyAsync" title="Copy">
                            <i class="bi @(_asymPublicKeyCopied ? "bi-check text-success" : "bi-copy")"></i>
                        </button>
                    </div>
                </div>
            }
            <div class="mb-3">
                <label class="form-label fw-semibold">Input</label>
                <textarea class="form-control form-control-sm" rows="2" @bind="_asymInput"
                          placeholder="Plaintext to encrypt, or ciphertext to decrypt"></textarea>
            </div>
            <div class="d-flex gap-2 mb-3">
                <button class="btn btn-primary btn-sm" @onclick="AsymEncryptAsync" disabled="@_busy">Encrypt</button>
                <button class="btn btn-outline-primary btn-sm" @onclick="AsymDecryptAsync" disabled="@_busy">Decrypt</button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="AsymReEncryptAsync" disabled="@_busy">Re-encrypt</button>
            </div>
            @if (_asymOutput != null)
            {
                <div class="mb-3">
                    <label class="form-label fw-semibold">Output</label>
                    <div class="d-flex align-items-start gap-1">
                        <textarea class="form-control form-control-sm font-monospace flex-grow-1" rows="1" style="field-sizing: content; resize: none;" onfocus="this.select()" readonly>@_asymOutput</textarea>
                        <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="CopyAsymOutputAsync" title="Copy">
                            <i class="bi @(_asymOutputCopied ? "bi-check text-success" : "bi-copy")"></i>
                        </button>
                    </div>
                </div>
            }
            @if (_asymError != null)
            {
                <div class="alert alert-danger py-2">@_asymError</div>
            }
        }
        else
        {
            @if (SigProvider != null)
            {
                <div class="mb-3">
                    <span class="badge bg-secondary">@SigProvider.ProviderName</span>
                    <small class="text-muted ms-2">@SigProvider.ProviderDescription</small>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Public Key</label>
                    <div class="d-flex align-items-start gap-1">
                        <textarea class="form-control form-control-sm font-monospace flex-grow-1" rows="1" style="field-sizing: content; resize: none;" onfocus="this.select()" readonly>@SigProvider.PublicKey</textarea>
                        <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="CopySigPublicKeyAsync" title="Copy">
                            <i class="bi @(_sigPublicKeyCopied ? "bi-check text-success" : "bi-copy")"></i>
                        </button>
                    </div>
                </div>
            }
            <div class="mb-3">
                <label class="form-label fw-semibold">Payload</label>
                <textarea class="form-control form-control-sm" rows="2" @bind="_sigPayload"
                          placeholder="Text to sign or verify"></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Signature</label>
                <textarea class="form-control form-control-sm font-monospace" rows="2" @bind="_sigSignature"
                          placeholder="Signature value (populated by Sign, required for Verify)"></textarea>
            </div>
            <div class="d-flex gap-2 mb-3">
                <button class="btn btn-primary btn-sm" @onclick="SignAsync" disabled="@_busy">Sign</button>
                <button class="btn btn-outline-primary btn-sm" @onclick="VerifyAsync" disabled="@_busy">Verify</button>
            </div>
            @if (_sigResult != null)
            {
                <div class="alert @(_sigResultIsValid == true ? "alert-success" : _sigResultIsValid == false ? "alert-danger" : "alert-info") py-2">@_sigResult</div>
            }
            @if (_sigError != null)
            {
                <div class="alert alert-danger py-2">@_sigError</div>
            }
        }
    </div>
</div>

@code {
    [Parameter]
    public IIamSymmetricEncryptionProvider? SymProvider { get; set; }

    [Parameter]
    public IIamAsymmetricEncryptionProvider? AsymProvider { get; set; }

    [Parameter]
    public IIamAsymmetricSignatureProvider? SigProvider { get; set; }

    private int _activeKeyTab;
    private bool _busy;

    private string _symInput = string.Empty;
    private string? _symOutput;
    private string? _symError;
    private bool _symOutputCopied;

    private string _asymInput = string.Empty;
    private string? _asymOutput;
    private string? _asymError;
    private bool _asymPublicKeyCopied;
    private bool _asymOutputCopied;

    private string _sigPayload = string.Empty;
    private string _sigSignature = string.Empty;
    private string? _sigResult;
    private bool? _sigResultIsValid;
    private string? _sigError;
    private bool _sigPublicKeyCopied;

    private async Task SymEncryptAsync()
    {
        if (string.IsNullOrWhiteSpace(_symInput)) return;
        _symOutput = null;
        _symError = null;
        await RunSafeAsync(() =>
        {
            if (SymProvider != null)
                _symOutput = SymProvider.Encrypt(_symInput);
        });
    }

    private async Task SymDecryptAsync()
    {
        if (string.IsNullOrWhiteSpace(_symInput)) return;
        _symOutput = null;
        _symError = null;
        await RunSafeAsync(() =>
        {
            if (SymProvider == null) return;
            try { _symOutput = SymProvider.Decrypt(_symInput); }
            catch (Exception ex) { _symError = $"Decryption failed: {ex.Message}"; }
        });
    }

    private async Task SymReEncryptAsync()
    {
        if (string.IsNullOrWhiteSpace(_symInput)) return;
        _symOutput = null;
        _symError = null;
        await RunSafeAsync(() =>
        {
            if (SymProvider == null) return;
            try { _symOutput = SymProvider.ReEncrypt(_symInput); }
            catch (Exception ex) { _symError = $"Re-encryption failed: {ex.Message}"; }
        });
    }

    private async Task AsymEncryptAsync()
    {
        if (string.IsNullOrWhiteSpace(_asymInput)) return;
        _asymOutput = null;
        _asymError = null;
        await RunSafeAsync(() =>
        {
            if (AsymProvider != null)
                _asymOutput = AsymProvider.Encrypt(_asymInput);
        });
    }

    private async Task AsymDecryptAsync()
    {
        if (string.IsNullOrWhiteSpace(_asymInput)) return;
        _asymOutput = null;
        _asymError = null;
        await RunSafeAsync(() =>
        {
            if (AsymProvider == null) return;
            try { _asymOutput = AsymProvider.Decrypt(_asymInput); }
            catch (Exception ex) { _asymError = $"Decryption failed: {ex.Message}"; }
        });
    }

    private async Task AsymReEncryptAsync()
    {
        if (string.IsNullOrWhiteSpace(_asymInput)) return;
        _asymOutput = null;
        _asymError = null;
        await RunSafeAsync(() =>
        {
            if (AsymProvider == null) return;
            try { _asymOutput = AsymProvider.ReEncrypt(_asymInput); }
            catch (Exception ex) { _asymError = $"Re-encryption failed: {ex.Message}"; }
        });
    }

    private async Task SignAsync()
    {
        if (string.IsNullOrWhiteSpace(_sigPayload)) return;
        _sigResult = null;
        _sigResultIsValid = null;
        _sigError = null;
        await RunSafeAsync(() =>
        {
            if (SigProvider != null)
            {
                _sigSignature = SigProvider.Sign(_sigPayload);
                _sigResult = "Payload signed. Signature populated below.";
            }
        });
    }

    private async Task VerifyAsync()
    {
        if (string.IsNullOrWhiteSpace(_sigPayload) || string.IsNullOrWhiteSpace(_sigSignature)) return;
        _sigResult = null;
        _sigResultIsValid = null;
        _sigError = null;
        await RunSafeAsync(() =>
        {
            if (SigProvider == null) return;
            try
            {
                var isValid = SigProvider.Verify(_sigPayload, _sigSignature);
                _sigResultIsValid = isValid;
                _sigResult = isValid ? "Signature is valid." : "Signature is invalid.";
            }
            catch (Exception ex) { _sigError = $"Verification failed: {ex.Message}"; }
        });
    }

    private async Task RunSafeAsync(Action action)
    {
        if (_busy) return;
        _busy = true;
        try
        {
            await Task.Run(action);
        }
        catch (Exception ex)
        {
            _symError ??= _asymError ??= _sigError ??= $"Operation failed: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task CopySymOutputAsync() => await CopyWithFeedbackAsync(_symOutput, v => _symOutputCopied = v);
    private async Task CopyAsymPublicKeyAsync() => await CopyWithFeedbackAsync(AsymProvider?.PublicKey, v => _asymPublicKeyCopied = v);
    private async Task CopyAsymOutputAsync() => await CopyWithFeedbackAsync(_asymOutput, v => _asymOutputCopied = v);
    private async Task CopySigPublicKeyAsync() => await CopyWithFeedbackAsync(SigProvider?.PublicKey, v => _sigPublicKeyCopied = v);

    private async Task CopyWithFeedbackAsync(string? text, Action<bool> setFlag)
    {
        if (string.IsNullOrEmpty(text)) return;
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", text);
        setFlag(true);
        StateHasChanged();
        await Task.Delay(1500);
        setFlag(false);
        StateHasChanged();
    }
}
