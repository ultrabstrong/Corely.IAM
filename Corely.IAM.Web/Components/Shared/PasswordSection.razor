@inject IRegistrationService RegistrationService
@inject IDeregistrationService DeregistrationService

<div class="section-divider mb-4 mt-4">
    <div class="section-divider-label">Password</div>
    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="mt-2">
            <Alert Message="@_message" Type="@_messageType" OnDismissed="() => _message = null" />
        </div>
    }
    @if (HasBasicAuth && HasGoogleAuth)
    {
        <p class="text-success mb-2"><i class="bi bi-check-circle me-1"></i>Password is set</p>
        @if (_showChangePassword)
        {
            <div class="d-flex gap-2 align-items-center mb-2">
                <input type="password" class="form-control form-control-sm" style="max-width: 200px;"
                       @bind="_newPassword" placeholder="New password" />
                <input type="password" class="form-control form-control-sm" style="max-width: 200px;"
                       @bind="_confirmPassword" placeholder="Confirm password" />
                <button class="btn btn-primary btn-sm" @onclick="SetAsync" disabled="@_busy">Save</button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="CancelChange">Cancel</button>
            </div>
        }
        else if (_showRemoveConfirm)
        {
            <p class="text-warning mb-2">Are you sure? You'll only be able to sign in with Google.</p>
            <div class="d-flex gap-2">
                <button class="btn btn-danger btn-sm" @onclick="RemoveAsync" disabled="@_busy">Confirm Remove</button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="() => _showRemoveConfirm = false">Cancel</button>
            </div>
        }
        else
        {
            <div class="d-flex gap-2">
                <button class="btn btn-outline-primary btn-sm" @onclick="() => _showChangePassword = true" disabled="@_busy">
                    Change Password
                </button>
                <button class="btn btn-outline-danger btn-sm" @onclick="() => _showRemoveConfirm = true" disabled="@_busy">
                    Remove Password
                </button>
            </div>
        }
    }
    else if (HasBasicAuth)
    {
        <p class="text-success mb-2"><i class="bi bi-check-circle me-1"></i>Password is set</p>
        @if (_showChangePassword)
        {
            <div class="d-flex gap-2 align-items-center mb-2">
                <input type="password" class="form-control form-control-sm" style="max-width: 200px;"
                       @bind="_newPassword" placeholder="New password" />
                <input type="password" class="form-control form-control-sm" style="max-width: 200px;"
                       @bind="_confirmPassword" placeholder="Confirm password" />
                <button class="btn btn-primary btn-sm" @onclick="SetAsync" disabled="@_busy">Save</button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="CancelChange">Cancel</button>
            </div>
        }
        else
        {
            <button class="btn btn-outline-primary btn-sm" @onclick="() => _showChangePassword = true" disabled="@_busy">
                Change Password
            </button>
            <p class="text-muted mt-2"><small>Add another sign-in method before removing your password.</small></p>
        }
    }
    else
    {
        <p class="text-muted mb-2">No password set. Add a password to enable username/password sign-in.</p>
        <div class="d-flex gap-2 align-items-center">
            <input type="password" class="form-control form-control-sm" style="max-width: 200px;"
                   @bind="_newPassword" placeholder="New password" />
            <input type="password" class="form-control form-control-sm" style="max-width: 200px;"
                   @bind="_confirmPassword" placeholder="Confirm password" />
            <button class="btn btn-primary btn-sm" @onclick="SetAsync" disabled="@_busy">Set Password</button>
        </div>
    }

</div>

@code {
    [Parameter]
    public bool HasBasicAuth { get; set; }

    [Parameter]
    public bool HasGoogleAuth { get; set; }

    [Parameter]
    public EventCallback OnStatusChanged { get; set; }

    private bool _showRemoveConfirm;
    private bool _showChangePassword;
    private string _newPassword = "";
    private string _confirmPassword = "";
    private bool _busy;
    private string? _message;
    private AlertType _messageType;

    private async Task RemoveAsync()
    {
        await RunSafeAsync(async () =>
        {
            var result = await DeregistrationService.DeregisterBasicAuthAsync();
            if (result.ResultCode == DeregisterBasicAuthResultCode.Success)
            {
                _showRemoveConfirm = false;
                SetMessage(true, "Password removed.");
                await OnStatusChanged.InvokeAsync();
            }
            else
            {
                SetMessage(false, result.Message);
            }
        });
    }

    private async Task SetAsync()
    {
        if (string.IsNullOrWhiteSpace(_newPassword))
        {
            SetMessage(false, "Password is required.");
            return;
        }
        if (_newPassword != _confirmPassword)
        {
            SetMessage(false, "Passwords do not match.");
            return;
        }
        await RunSafeAsync(async () =>
        {
            var result = await RegistrationService.SetPasswordAsync(new SetPasswordRequest(_newPassword));
            if (result.ResultCode == SetPasswordResultCode.Success)
            {
                CancelChange();
                SetMessage(true, HasBasicAuth ? "Password changed successfully." : "Password set successfully.");
                await OnStatusChanged.InvokeAsync();
            }
            else
            {
                SetMessage(false, result.Message);
            }
        });
    }

    private void CancelChange()
    {
        _showChangePassword = false;
        _newPassword = "";
        _confirmPassword = "";
    }

    private async Task RunSafeAsync(Func<Task> action)
    {
        if (_busy) return;
        _busy = true;
        try { await action(); }
        catch { SetMessage(false, "An unexpected error occurred."); }
        finally { _busy = false; }
    }

    private void SetMessage(bool success, string text)
    {
        _message = text;
        _messageType = success ? AlertType.Success : AlertType.Danger;
    }
}
