@inject IMfaService MfaService
@inject IJSRuntime JSRuntime

<div class="section-divider mb-4 mt-4">
    <div class="section-divider-label">Two-Factor Authentication</div>
    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="mt-2">
            <Alert Message="@_message" Type="@_messageType" OnDismissed="() => _message = null" />
        </div>
    }
    @if (_setupPhase)
    {
        <div class="d-flex gap-4 align-items-start flex-wrap mb-2">
            <div class="flex-shrink-0" style="min-width: 150px; max-width: 100%;">
                <div><strong><i class="bi bi-qr-code me-1"></i>QR Code</strong> <span class="text-muted fw-normal" style="font-size: 0.85rem;">Secret: <code class="user-select-all text-danger" style="font-size: 0.85rem;">@_secret</code></span></div>
                <div class="text-muted mt-1" style="font-size: 0.85rem; white-space: normal; word-break: break-word;">Scan the QR code with your authenticator app, or enter the secret manually.</div>
                <div class="mt-4 mb-2 text-center">
                    <div id="totp-qrcode" style="display: inline-block;"></div>
                </div>
            </div>
            <div class="flex-fill">
                <div><strong><i class="bi bi-key me-1"></i>Recovery Codes</strong></div>
                <div class="text-muted mt-1 mb-2" style="font-size: 0.85rem;">Save these, each can only be used once</div>
                <div class="d-flex justify-content-center justify-content-md-start mt-4">
                    <div class="d-inline-grid" style="grid-template-columns: repeat(2, auto); column-gap: 1.5rem; row-gap: 0; font-family: monospace; font-size: 0.85rem;">
                        @foreach (var rc in _recoveryCodes)
                        {
                            <div>@rc</div>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="d-flex gap-2 align-items-center justify-content-center justify-content-md-start mt-4">
            <input type="text" class="form-control form-control-sm" style="max-width: 200px;"
                   @bind="_confirmCode" placeholder="Enter code to confirm" />
            <button class="btn btn-primary btn-sm" @onclick="ConfirmAsync" disabled="@_busy">Confirm</button>
            <button class="btn btn-outline-secondary btn-sm" @onclick="CancelSetup">Cancel</button>
        </div>
    }
    else if (_enabled)
    {
        <p class="text-success mb-2"><i class="bi bi-shield-check me-1"></i>Enabled (@_remainingCodes remaining recovery codes)</p>
        @if (_regeneratedCodes != null)
        {
            <div class="mt-3 mb-3">
                <div><strong><i class="bi bi-key me-1"></i>Recovery Codes</strong></div>
                <div class="text-muted mt-1 mb-2" style="font-size: 0.85rem;">Save these, each can only be used once</div>
                <div class="d-flex justify-content-center justify-content-md-start mt-3">
                    <div class="d-inline-grid" style="grid-template-columns: repeat(2, auto); column-gap: 1.5rem; row-gap: 0; font-family: monospace; font-size: 0.85rem;">
                        @foreach (var rc in _regeneratedCodes)
                        {
                            <div>@rc</div>
                        }
                    </div>
                </div>
            </div>
        }
        @if (_showDisableInput)
        {
            <div class="d-flex gap-2 align-items-center mb-2">
                <input type="text" class="form-control form-control-sm" style="max-width: 200px;"
                       @bind="_disableCode" placeholder="Enter current TOTP code" />
                <button class="btn btn-danger btn-sm" @onclick="DisableAsync" disabled="@_busy">Confirm Disable</button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="() => _showDisableInput = false">Cancel</button>
            </div>
        }
        else
        {
            <div class="d-flex gap-2">
                <button class="btn btn-outline-warning btn-sm" @onclick="RegenerateAsync" disabled="@_busy">
                    Regenerate Recovery Codes
                </button>
                <button class="btn btn-outline-danger btn-sm" @onclick="() => _showDisableInput = true" disabled="@_busy">
                    Disable
                </button>
            </div>
        }
    }
    else
    {
        <p class="text-muted mb-2">Protect your account with TOTP-based two-factor authentication.</p>
        <button class="btn btn-outline-primary btn-sm" @onclick="EnableAsync" disabled="@_busy">
            Enable Two-Factor Authentication
        </button>
    }


</div>

@code {
    [Parameter]
    public EventCallback OnStatusChanged { get; set; }

    private bool _enabled;
    private bool _setupPhase;
    private string? _secret;
    private string? _setupUri;
    private string[] _recoveryCodes = [];
    private string _confirmCode = "";
    private string _disableCode = "";
    private bool _showDisableInput;
    private string[]? _regeneratedCodes;
    private int _remainingCodes;
    private bool _pendingQrRender;
    private bool _busy;
    private string? _message;
    private AlertType _messageType;

    protected override async Task OnInitializedAsync()
    {
        await LoadStatusAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingQrRender && !string.IsNullOrWhiteSpace(_setupUri))
        {
            _pendingQrRender = false;
            await JSRuntime.InvokeVoidAsync("qrCodeInterop.generate", "totp-qrcode", _setupUri, 150);
        }
    }

    private async Task LoadStatusAsync()
    {
        var status = await MfaService.GetTotpStatusAsync();
        if (status.ResultCode == TotpStatusResultCode.Success)
        {
            _enabled = status.IsEnabled;
            _remainingCodes = status.RemainingRecoveryCodes;
        }
    }

    private async Task EnableAsync()
    {
        await RunSafeAsync(async () =>
        {
            var result = await MfaService.EnableTotpAsync();
            if (result.ResultCode == EnableTotpResultCode.Success)
            {
                _setupPhase = true;
                _secret = result.Secret;
                _setupUri = result.SetupUri;
                _recoveryCodes = result.RecoveryCodes ?? [];
                _regeneratedCodes = null;
                _pendingQrRender = true;
            }
            else
            {
                SetMessage(false, result.Message);
            }
        });
    }

    private async Task ConfirmAsync()
    {
        if (string.IsNullOrWhiteSpace(_confirmCode)) return;
        await RunSafeAsync(async () =>
        {
            var result = await MfaService.ConfirmTotpAsync(new ConfirmTotpRequest(_confirmCode.Trim()));
            if (result.ResultCode == ConfirmTotpResultCode.Success)
            {
                _setupPhase = false;
                _enabled = true;
                _confirmCode = "";
                await LoadStatusAsync();
                SetMessage(true, "Two-factor authentication enabled.");
                await OnStatusChanged.InvokeAsync();
            }
            else
            {
                SetMessage(false, result.Message);
            }
        });
    }

    private void CancelSetup()
    {
        _setupPhase = false;
        _secret = null;
        _setupUri = null;
        _recoveryCodes = [];
        _confirmCode = "";
    }

    private async Task RegenerateAsync()
    {
        await RunSafeAsync(async () =>
        {
            var result = await MfaService.RegenerateTotpRecoveryCodesAsync();
            if (result.ResultCode == RegenerateTotpRecoveryCodesResultCode.Success)
            {
                _regeneratedCodes = result.RecoveryCodes;
                await LoadStatusAsync();
                SetMessage(true, "Recovery codes regenerated. Save them now.");
            }
            else
            {
                SetMessage(false, result.Message);
            }
        });
    }

    private async Task DisableAsync()
    {
        if (string.IsNullOrWhiteSpace(_disableCode)) return;
        await RunSafeAsync(async () =>
        {
            var result = await MfaService.DisableTotpAsync(new DisableTotpRequest(_disableCode.Trim()));
            if (result.ResultCode == DisableTotpResultCode.Success)
            {
                _enabled = false;
                _showDisableInput = false;
                _disableCode = "";
                _regeneratedCodes = null;
                SetMessage(true, "Two-factor authentication disabled.");
                await OnStatusChanged.InvokeAsync();
            }
            else
            {
                SetMessage(false, result.Message);
            }
        });
    }

    private async Task RunSafeAsync(Func<Task> action)
    {
        if (_busy) return;
        _busy = true;
        try { await action(); }
        catch { SetMessage(false, "An unexpected error occurred."); }
        finally { _busy = false; }
    }

    private void SetMessage(bool success, string text)
    {
        _message = text;
        _messageType = success ? AlertType.Success : AlertType.Danger;
    }
}
