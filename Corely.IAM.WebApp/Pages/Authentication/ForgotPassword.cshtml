@page "/forgot-password"
@model Corely.IAM.WebApp.Pages.Authentication.ForgotPasswordModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-card">
    <h2 class="mb-3">Forgot Password</h2>
    <p class="text-muted">
        This reference app demonstrates how a host can request password recovery through
        <code>IPasswordRecoveryService</code> and decide how to handle delivery.
    </p>

    <div class="alert alert-secondary" role="alert">
        This demo host surfaces library-facing results directly. A production host could instead show generic
        end-user messaging and deliver the recovery link through email or another channel.
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.InfoMessage))
    {
        <div class="alert alert-info" role="alert">@Model.InfoMessage</div>
    }

    <form method="post">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input type="email" class="form-control" id="email" name="Email" value="@Model.Email" required autofocus />
        </div>
        <button type="submit" class="btn btn-primary w-100">Request Password Recovery</button>
    </form>

    @if (Model.IsPreviewEnabled)
    {
        <div class="mt-3">
            <a href="@Corely.IAM.WebApp.WebAppRoutes.PasswordRecoveryPreview">Open Demo Recovery Preview</a>
        </div>
    }

    <div class="mt-3">
        <a href="@Corely.IAM.Web.AppRoutes.SignIn">Back to Sign In</a>
    </div>
</div>
