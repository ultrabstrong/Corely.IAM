@page "/forgot-password-preview"
@model Corely.IAM.WebApp.Pages.Authentication.PasswordRecoveryPreviewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Recovery Preview";
}

<div class="auth-card">
    <h2 class="mb-3">Demo Recovery Preview</h2>
    <p class="text-muted">
        This page stands in for email delivery in the reference app. In a real host, the token or reset link would
        be sent through a trusted delivery channel instead of rendered in the UI.
    </p>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-warning" role="alert">@Model.ErrorMessage</div>
    }
    else
    {
        <div class="mb-3">
            <label class="form-label">Requested Email</label>
            <input type="text" class="form-control" value="@Model.Email" readonly />
        </div>
        <div class="mb-3">
            <label class="form-label">Recovery Token</label>
            <textarea class="form-control" rows="4" readonly>@Model.RecoveryToken</textarea>
        </div>
        <div class="d-grid gap-2">
            <a class="btn btn-primary" href="@Model.ResetPasswordUrl">Open Reset Password Demo</a>
            <a class="btn btn-outline-secondary" href="@Corely.IAM.WebApp.WebAppRoutes.ForgotPassword">Back to Forgot Password</a>
        </div>
    }
</div>
